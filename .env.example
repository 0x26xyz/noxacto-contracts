# noxacto-contracts — deploy config. Copy to .env; NEVER commit the real file.
# Foundry scripts read these via vm.envUint / vm.envAddress.

# ---- Signer (the deployer EOA; becomes the cold OWNER of the contracts) ----
# Must be funded on BOTH chains. Keep this OUT of git.
PRIVATE_KEY=

# ---- RPC endpoints ----
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com   # Robinhood Chain (wNOXA + migrator)
DBK_RPC_URL=https://rpc.mainnet.dbkchain.io          # DBK Chain (lockbox)
RH_CHAIN_ID=4663
DBK_CHAIN_ID=20240603

# ---- Keys ----
# DBK-funded key that broadcasts DBK deploys (NoxaLockboxV3). Keep OUT of git.
DBK_DEPLOY_KEY=

# ---- WrappedNoxaV3 (RH) ----
# Cold owner (a Safe once available; an EOA to start is fine — ownership is transferable).
BRIDGE_AUTHORITY=
# Hard supply cap = the real DBK NOXA total supply (1,000,000e18). Bounds a compromised minter.
WNOXA_MAX_SUPPLY=1000000000000000000000000
# Mirrored source-token wallet cap. Read the live getter before deploying:
#   cast call $NOXA_ADDRESS "maxWalletAmount()(uint256)" --rpc-url $DBK_RPC_URL
WNOXA_MAX_WALLET=25000000000000000000000

# ---- NoxaLockboxV3 (DBK) — leaky-bucket rate limit, one box per wNOXA version ----
NOXA_ADDRESS=0x6778980c66bcd9A8F74D73BD1b608483c40E8DdE   # real NOXA on DBK (verify on-chain)
WRAPPED_NOXA_ADDRESS=          # the RH wNOXA this box settles for (recorded on-chain)
BRIDGE_AUTHORITY_COLD=         # cold owner (Safe/EOA) — manages unlocker, budgets, pause
BRIDGE_UNLOCKER=               # hot relayer key allowed to call unlock (may be 0, set later)
# Hot-path leaky buckets. Size the VALUE cap to a fraction of collateral you can
# afford to lose to a leaked key before you pause (minutes). Both MUST be non-zero.
UNLOCK_CAP_PER_WINDOW=         # e.g. 5000000000000000000 (5 NOXA) — VALUE per window
UNLOCK_COUNT_PER_WINDOW=20     # settlements per window (bounds nonce-griefing)
UNLOCK_WINDOW=600              # leaky-bucket decay length in seconds (10 min)

# NOTE: NoxaLockboxV2 and its UNLOCK_CAP / UNLOCK_COOLDOWN=0 config are DEPRECATED
# (per-tx cap + cooldown=0 was defeatable — see docs/noxa-wallet-cap.md and the
# 2026-07 review). Deploy NoxaLockboxV3 with the leaky-bucket vars above instead.

# ---- WNoxaMigrator (RH) — old -> new wNOXA, 1:1 escrow ----
OLD_WNOXA=       # the deprecated wNOXA to escrow (e.g. v2 during a v2 -> v3 cutover)
NEW_WNOXA=       # the hardened wNOXA to mint (WrappedNoxaV3)
MIGRATOR_OWNER=  # owner (can pause + sweep escrow for reconciliation)

# ---- NoxaFeeBurner + seed (RH) — deployed at seed time ----
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73   # RH WETH (verify on-chain)
SWAP_ROUTER=0xcaf681a66d020601342297493863e78c959e5cb2   # SwapRouter02 (NOT UniversalRouter)
LAUNCH_FEE_TIER=10000                                     # 1% pool
BURN_KEEPER=            # keeper EOA allowed to call burn() — MANDATORY (MED-2)
BURN_KEEPER_OWNER=      # cold owner that can rotate a leaked keeper (defaults to BRIDGE_AUTHORITY)
# Seed (SeedWrappedNoxaLiquidity) — read the DBK NOXA/WETH pool slot0 at seed time:
UNISWAP_V3_FACTORY=0x1f7d7550B1b028f7571E69A784071F0205FD2EfA
UNISWAP_V3_POSITION_MANAGER=0x73991a25C818Bf1f1128dEAaB1492D45638DE0D3
SEED_WNOXA_AMOUNT=        # wNOXA to seed (the broadcaster must hold it)
SEED_FEE_RECIPIENT=      # the deployed NoxaFeeBurner
SEED_SQRT_PRICE_X96=     # from the DBK NOXA/WETH pool slot0 at seed time
SEED_TICK_LOWER=         # see ~/plans/wnoxa-trade-activation.md seed runbook
SEED_TICK_UPPER=
