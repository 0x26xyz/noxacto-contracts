# noxacto-contracts — deploy config. Copy to .env; NEVER commit the real file.
# Foundry scripts read these via vm.envUint / vm.envAddress.

# ---- Signer (the deployer EOA; becomes the cold OWNER of the contracts) ----
# Must be funded on BOTH chains. Keep this OUT of git.
PRIVATE_KEY=

# ---- RPC endpoints ----
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com   # Robinhood Chain (wNOXA + migrator)
DBK_RPC_URL=https://rpc.mainnet.dbkchain.io          # DBK Chain (lockbox)
RH_CHAIN_ID=4663
DBK_CHAIN_ID=20240603

# ---- WrappedNoxaV2 (RH) ----
# Cold owner (a Safe once available; an EOA to start is fine — ownership is transferable).
BRIDGE_AUTHORITY=
# Hard supply cap = the real DBK NOXA total supply (1,000,000e18). Bounds a compromised minter.
WNOXA_MAX_SUPPLY=1000000000000000000000000

# ---- NoxaLockboxV2 (DBK) ----
NOXA_ADDRESS=0x6778980c66bcd9A8F74D73BD1b608483c40E8DdE   # real NOXA on DBK (verify on-chain)
UNLOCKER=                       # hot relayer key allowed to call unlock (rate-limited)
UNLOCK_CAP=40000000000000000000 # per-tx release cap on the hot path (40e18)
UNLOCK_COOLDOWN=0               # min seconds between hot-path unlocks (tighten later)

# ---- WNoxaMigrator (RH) — old -> new wNOXA, 1:1 escrow ----
OLD_WNOXA=       # the deprecated wNOXA to escrow
NEW_WNOXA=       # the hardened WrappedNoxaV2 to mint
MIGRATOR_OWNER=  # owner (can pause + sweep escrow for reconciliation)
